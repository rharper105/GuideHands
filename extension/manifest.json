{
    "manifest_version": 3,
    "name": "GuideHands",
    "version": "1.0.0",
    "description": "Your visual co-pilot for navigating complex digital interfaces and portals.",
    "permissions": [
        "activeTab",
        "sidePanel",
        "scripting",
        "tabs"
    ],
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_title": "Open GuideHands"
    }
}